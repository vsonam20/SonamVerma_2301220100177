1. Sort Colors(LeetCode 75)...

class Solution {
    public void sortColors(int[] nums) {
        int n = nums.length;
         for(int i = 0; i < n - 1; i++) 
         {
            for(int j = i+1; j < n; j++) 
            {
                if(nums[i] > nums[j]) 
                {
                    nums[i]=nums[i]+nums[j];
                    nums[j]=nums[i]-nums[j];
                    nums[i]=nums[i]-nums[j];
                }
            }
        }
    }
}

