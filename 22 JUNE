2. QUES 94 INORDER

class Solution {
    public List<Integer> inorderTraversal(TreeNode root) {
        List<Integer> result=new ArrayList<>();
        inorder(root,result);
        return result;
    }
    void inorder(TreeNode node,List<Integer> result){
        if(node==null) return;

        inorder(node.left,result);
        result.add(node.val);
        inorder(node.right,result);
}
}
