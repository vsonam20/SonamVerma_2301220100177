4. QUES LEETCODE 102

class Solution {
    public List<List<Integer>> levelOrder(TreeNode root) {
        List<List<Integer>> result=new ArrayList<>();
        if(root==null) return result;
        Queue<TreeNode> queue=new LinkedList<>();           // stores one node along with its left and ryt pointer
        queue.offer(root);    
        while(!queue.isEmpty()){
            int size=queue.size();                          // the size of queue will grow 
            List<Integer> l=new ArrayList<>();
            for(int i=0;i<size;i++){
                TreeNode node=queue.poll();                   // the node is removed from queue and added to l
                l.add(node.val);
                if(node.left!=null) queue.offer(node.left); 
                if(node.right!=null) queue.offer(node.right);
                

            }
            result.add(l);

        }
        return result;

    }
}
